PORT=8080
HOST=0.0.0.0
NODE_ENV=development
DATABASE_URL="postgresql://postgres:7.~O/.S\U[{;M.;N@34.71.61.169:5432/postgres"
# En Cloud Run se pueden usar DB_HOST, DB_PORT, DB_NAME, DB_USER y DB_PASSWORD
# en lugar de DATABASE_URL.
#
# Conexion a Cloud SQL desde Cloud Run (recomendado): se conecta por un unix socket
# en /cloudsql/<INSTANCE_CONNECTION_NAME> en lugar de la IP publica. Define una de:
#   INSTANCE_CONNECTION_NAME=mi-proyecto:us-central1:mi-instancia
#   # o la ruta completa del socket:
#   INSTANCE_UNIX_SOCKET=/cloudsql/mi-proyecto:us-central1:mi-instancia
# junto con DB_NAME, DB_USER y DB_PASSWORD. Tiene prioridad sobre DATABASE_URL.
#
# Nota: la password del DATABASE_URL de arriba contiene caracteres especiales
# (/ \ [ { ;) que rompen el parser de URL de pg; para conexiones locales/IP usa
# las variables DB_USER/DB_PASSWORD en vez de DATABASE_URL.
DB_POOL_MAX=10
JWT_SECRET=replace-with-at-least-32-characters
ADMIN_TOKEN=replace-with-a-different-secret
CORS_ORIGINS=http://localhost:5173
CORS_ORIGIN_PATTERNS=https://*.vercel.app,https://*.netlify.app
RATE_LIMIT_PER_WORKSPACE=600
# En el arranque, el server migra siempre y hace seed una sola vez si la BD esta
# vacia (advisory lock para que solo una instancia siembre). Pon false para desactivar.
SEED_ON_BOOT=true
SEED_PASSWORD_PREFIX=Pizza
SEED_WORKSPACE_COUNT=100
SEED_TROPELS_PER_WORKSPACE=120
SEED_SIGNALS_PER_WORKSPACE=600
